{
  "name": "vite",
  "description": "Include Bootstrap's source Sass and individual JavaScript plugins with Vite.",
  "version": "0.0.0",
  "private": true,
  "stackblitz": {
    "startCommand": "npm start"
  },
  "scripts": {
    "compile-sass": "npx sass assets/scss/styles.scss assets/css/styles.min.css --style compressed",
    "compile-public-vanilla": "npx sass assets/scss/public-vanilla.scss assets/css/public-vanilla.min.css --style compressed",
    "watch-sass": "npx sass --watch assets/scss/styles.scss assets/css/styles.min.css --style compressed"
  },
  "devDependencies": {
    "sass": "^1.54.8"
  },
  "dependencies": {
    "apexcharts": "^3.54.1",
    "bootstrap": "^5.3.3",
    "jquery": "^3.6.3"
  }
}
